{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/worker/**/*.ts", "src/lib/**/*.ts", "src/scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    "src/lib/stripe.ts",
    "src/**/__tests__/**",
    "src/**/*.test.ts"
  ]
}
