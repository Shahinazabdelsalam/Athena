generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum PostStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PostFormat {
  BLOG
  LINKEDIN
  CAROUSEL
  THREAD
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  name                 String?
  passwordHash         String?
  image                String?
  business             String?
  plan                 Plan        @default(FREE)
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  postsThisMonth       Int         @default(0)
  monthResetAt         DateTime    @default(now())
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  posts                Post[]
  accounts             Account[]
  sessions             Session[]
  brandVoice           BrandVoice?
}

model BrandVoice {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  soul             String
  audience         String
  toneRules        String[]
  bannedWords      String[]
  mandatoryAnchors String[]
  pillars          Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Post {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  business        String
  topic           String
  format          PostFormat @default(LINKEDIN)
  title           String?
  content         String?
  metaDescription String?
  wordCount       Int?
  charCount       Int?
  status           PostStatus @default(PENDING)
  jobId            String?
  error            String?
  pillar           String?
  alternativeHooks String[]
  followUpIdeas    String[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
